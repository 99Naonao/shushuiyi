{
	"easycom": {
		// npm安装的方式不需要前面的"@/"，下载安装的方式需要"@/"
		// npm安装方式
		// "^u-(.*)": "uview-ui/components/u-$1/u-$1.vue"
		// 下载安装方式
		"^u-(.*)": "@/uni_modules/uview-ui/components/u-$1/u-$1.vue",
		// "^z-(.*)": "@/uni_modules/z-$1/components/z-$1/z-$1.vue",s
		"^mix-(.*)": "@/components/mix-$1/mix-$1.vue"
	},
	"pages": [ //pages数组中第一项表示应用启动页，参考：https://uniapp.dcloud.io/collocation/pages
		{
			"path": "pages/index/index",
			"style": {
				"navigationStyle": "custom"
			}
		}, {
			"path": "pages/mine/webview",
			"style": {
				"navigationStyle": "custom"
			}
		},
		{
			"path": "pages/help/help",
			"style": {
				"navigationStyle": "custom"
			}
		},
		{
			"path": "pages/product/product",
			"style": {
				"navigationStyle": "custom"
			}
		},
		{
			"path": "pages/mine/mine",
			"style": {
				"navigationStyle": "custom"
			}
		}
	],
	"requiredBackgroundModes": ["audio"],
	"subPackages": [{
		"root": "page_subject",
		"pages": [{
			"path": "work/work",
			"style": {
				"navigationStyle": "custom",
				"navigationBarTitleText": "连接设备"
			}
		}, {
			"path": "adjust/adjust",
			"style": {
				"navigationStyle": "custom",
				"navigationBarTitleText": "手动调整"
			}
		}, {
			"path": "play/play",
			"style": {
				"navigationStyle": "custom",
				"navigationBarTitleText": "播放"
			}
		}, {
			"path": "selectMore/selectMore",
			"style": {
				"navigationStyle": "custom",
				"navigationBarTitleText": "请选择您喜爱的佩戴方式"
			}
		}, {
			"path": "step/step",
			"style": {
				"navigationStyle": "custom",
				"navigationBarTitleText": "进阶设置"
			}
		}]
	}],
	"globalStyle": {
		"navigationBarTextStyle": "black",
		"navigationBarTitleText": "助眠仪",
		"navigationBarBackgroundColor": "#F8F8F8",
		"backgroundColor": "#F8F8F8"
	},
	"uniIdRouter": {},
	"window": {
		"backgroundColor": "#F6F6F6",
		"backgroundTextStyle": "light",
		"navigationBarBackgroundColor": "#F6F6F6",
		"navigationBarTitleText": "首页",
		"navigationBarTextStyle": "black",
		"navigationStyle": "custom"
	},
	"tabBar": {
		"custom": true,
		"color": "#CCCCCC",
		"selectedColor": "#0066d4",
		"list": [{
				"pagePath": "pages/index/index",
				"iconPath": "./static/index/SY_00_buttonSYa.png",
				"selectedIconPath": "./static/index/SY_00_buttonSYb.png",
				"text": ""
			},
			{
				"pagePath": "pages/help/help",
				"iconPath": "./static/index/SY_00_buttonBZa.png",
				"selectedIconPath": "./static/index/SY_00_buttonBZb.png",
				"text": ""
			},
			{
				"pagePath": "pages/product/product",
				"iconPath": "./static/index/SY_00_buttonCPa.png",
				"selectedIconPath": "./static/index/SY_00_buttonCPb.png",
				"text": ""
			},
			{
				"pagePath": "pages/mine/mine",
				"iconPath": "./static/index/SY_00_buttonWDa.png",
				"selectedIconPath": "./static/index/SY_00_buttonWDb.png",
				"text": ""
			}
		]
	}
}